<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "1420"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES">
      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Run Script"
               scriptText = "#!/bin/bash&#10;&#10;# Define variables&#10;OPENAPI_REPO=&quot;https://github.com/FeedbackFriends/feedback-openapi.git&quot;&#10;TARGET_DIR=&quot;$HOME/Documents/Projects/feedback-app-ios/Modules/Sources/Helpers/APIClient&quot;&#10;TARGET_FILE=&quot;$TARGET_DIR/openapi.yaml&quot;&#10;TEMP_DIR=$(mktemp -d)&#10;&#10;echo &quot;Cloning feedback-openapi repository into temporary directory...&quot;&#10;git clone --depth 1 &quot;$OPENAPI_REPO&quot; &quot;$TEMP_DIR&quot;&#10;&#10;if [ -f &quot;$TEMP_DIR/openapi.yaml&quot; ]; then&#10;    echo &quot;Found openapi.yaml, moving it to $TARGET_DIR...&quot;&#10;    &#10;    # Ensure the target directory exists&#10;    mkdir -p &quot;$TARGET_DIR&quot;&#10;    &#10;    # Move the file&#10;    mv &quot;$TEMP_DIR/openapi.yaml&quot; &quot;$TARGET_FILE&quot;&#10;    &#10;    echo &quot;&#x2705; Successfully updated openapi.yaml!&quot;&#10;else&#10;    echo &quot;&#x274c; Failed to find openapi.yaml in the repository!&quot;&#10;    exit 1&#10;fi&#10;&#10;# Clean up temporary directory&#10;rm -rf &quot;$TEMP_DIR&quot;&#10;&#10;echo &quot;Done.&quot;&#10;&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "B1057F332843FD8600B9EE2F"
                     BuildableName = "Lets Grow.app"
                     BlueprintName = "Feedback"
                     ReferencedContainer = "container:Feedback.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "YES"
            buildForArchiving = "YES"
            buildForAnalyzing = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "B1057F332843FD8600B9EE2F"
               BuildableName = "Lets Grow.app"
               BlueprintName = "Feedback"
               ReferencedContainer = "container:Feedback.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
